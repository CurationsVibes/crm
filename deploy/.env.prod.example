# ============================================================
# CurationsVibes CRM — Production Environment Template
# ============================================================
# Copy this file to .env.prod and fill in every REQUIRED value.
# Never commit .env.prod to git.
#
# Generate secret tokens with:
#   openssl rand -base64 32
# ============================================================

# ── Docker image version ─────────────────────────────────────
TAG=latest

# ── Core application ─────────────────────────────────────────

# REQUIRED: Primary URL where users access the CRM.
# Use https:// — Cloudflare Tunnel provides the SSL certificate.
# Example: https://crm.curations.org
SERVER_URL=https://crm.curations.org

# REQUIRED: Random secret for JWT signing.
# Generate: openssl rand -base64 32
APP_SECRET=REPLACE_ME_openssl_rand_base64_32

# ── Database ─────────────────────────────────────────────────

# REQUIRED: Strong Postgres password (no special characters).
# Generate: openssl rand -hex 32
PG_DATABASE_PASSWORD=REPLACE_ME_openssl_rand_hex_32

# Optional: change default user if desired.
PG_DATABASE_USER=postgres

# ── Email via Resend ─────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
# Add your domain (curations.org / curationsla.com) in Resend → Domains
# and verify DNS records in Cloudflare.

# REQUIRED: Your Resend API key (starts with re_)
RESEND_API_KEY=re_REPLACE_ME_with_your_resend_api_key

# REQUIRED: The "From" address for system emails.
# Must use a verified domain in Resend.
EMAIL_FROM_ADDRESS=crm@curations.org

# REQUIRED: Display name shown in email clients.
EMAIL_FROM_NAME=CURATIONS CRM

# Require users to verify their email before signing in.
IS_EMAIL_VERIFICATION_REQUIRED=true

# ── Cloudflare Tunnel ─────────────────────────────────────────
# Steps to get your tunnel token:
# 1. Log in to Cloudflare Zero Trust (one.dash.cloudflare.com)
# 2. Go to Networks → Tunnels → Create a Tunnel
# 3. Name it (e.g. "curations-crm-prod") → Next
# 4. Choose Docker → Copy the token shown in the command
# 5. In Public Hostnames, add:
#      Subdomain: crm   Domain: curations.org   → http://server:3000
#      Subdomain: crm   Domain: curationsla.com → http://server:3000
#    (Both domains can share the same tunnel.)

# REQUIRED: Token from Cloudflare Zero Trust tunnel configuration.
CLOUDFLARE_TUNNEL_TOKEN=REPLACE_ME_cloudflare_tunnel_token

# Optional: Used by Twenty's built-in Cloudflare webhook integrations.
CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_WEBHOOK_SECRET=

# ── AI — Claude / Anthropic ───────────────────────────────────
# Sign up at https://console.anthropic.com and create an API key.
# Enables AI summaries, drafting, enrichment, and workflow automations.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME_with_your_anthropic_api_key

# ── Workspace settings ────────────────────────────────────────
# true  = only server admins can create new workspaces (recommended for production).
IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=true

# true  = allow multiple workspaces (needed for CURATIONS + CurationsLA isolation).
IS_MULTIWORKSPACE_ENABLED=true

# ── Authentication ────────────────────────────────────────────
AUTH_PASSWORD_ENABLED=true

# Google SSO (optional — configure in Google Cloud Console).
AUTH_GOOGLE_ENABLED=false
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# ── File storage ──────────────────────────────────────────────
# Default: local volume inside Docker.
# Switch to s3 once you add Cloudflare R2 or AWS S3.
STORAGE_TYPE=local

# ── S3-compatible storage (Cloudflare R2 recommended) ─────────
# Uncomment and fill in when switching from local storage.
# Cloudflare R2 credentials are under R2 → Manage API tokens.
#
# STORAGE_TYPE=s3
# STORAGE_S3_REGION=auto
# STORAGE_S3_NAME=curations-crm
# STORAGE_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# ── Rate limiting ─────────────────────────────────────────────
API_RATE_LIMITING_TTL=1000
API_RATE_LIMITING_LIMIT=500

# ── Token expiry ──────────────────────────────────────────────
# Adjust to taste; defaults are conservative for a single-seat deployment.
ACCESS_TOKEN_EXPIRES_IN=30m
LOGIN_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=90d
FILE_TOKEN_EXPIRES_IN=1d
PASSWORD_RESET_TOKEN_EXPIRES_IN=5m

# ── Backup (used by backup.sh) ────────────────────────────────
# Local path on the host where backups are written before optional upload.
BACKUP_DIR=/opt/curations-crm/backups

# Cloudflare R2 (or any S3-compatible bucket) for off-site backup storage.
# Leave blank to keep backups local only.
# Create R2 credentials: Cloudflare dashboard → R2 → Manage R2 API tokens
# See also: deploy/README.md § Phase 8.3 (Off-site backup with Cloudflare R2)
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_REGION=auto
